{
  "manifest_version": 3,
  "name": "课程笔记助手",
  "version": "1.0.0",
  "description": "在线学习笔记收集工具，支持划线收藏、待复习、课程目录和导出功能",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "contextMenus",
    "alarms",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "课程笔记助手",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel/*", "pages/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
